// Prisma schema for AI Bias Detection Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  audits    Audit[]
  createdAt DateTime @default(now())
}

model Audit {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName      String
  targetColumn  String
  protectedCols String[]
  profileJson   Json
  resultsJson   Json
  riskLevel     String
  createdAt     DateTime @default(now())
}
